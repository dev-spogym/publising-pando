{
  "name": "v1-publishing",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration && npm run test:contract && npm run test:snapshot && npm run test:e2e",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify:coverage": "tsx scripts/verify-coverage.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "serve out -l 3100",
    "docs:handoff": "tsx scripts/generate-handoff-docs.ts",
    "verify:handoff": "npm run docs:handoff && tsx scripts/verify-handoff.ts",
    "visual:audit": "tsx scripts/visual-audit.ts",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/**/*.test.ts",
    "test:contract": "node --import tsx --test tests/contract/**/*.test.ts",
    "test:snapshot": "node --import tsx --test tests/snapshot/**/*.test.ts",
    "test:smoke": "playwright test tests/e2e/smoke-sanity-regression.spec.ts",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.ts",
    "test:responsive": "playwright test tests/e2e/responsive.spec.ts",
    "test:visual-regression": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:cross-browser": "playwright test --config playwright.cross-browser.config.ts",
    "test:publishing:all": "npm run verify:coverage && npm run verify:handoff && npm run test:unit && npm run test:integration && npm run test:contract && npm run test:snapshot && npm run build && npm run test:smoke && npm run test:accessibility && npm run test:responsive && npm run test:e2e -- tests/e2e/admin-pando-screens.spec.ts tests/e2e/product-management.spec.ts tests/e2e/full-page-coverage.spec.ts && npm run test:visual-regression && npm run test:cross-browser && npm run visual:audit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
